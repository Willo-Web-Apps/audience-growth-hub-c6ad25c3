---
---
<header class="sticky top-0 z-50 border-b border-surface-200 bg-surface-50/90 backdrop-blur-md">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-7 h-7 rounded-md bg-brand-500 flex items-center justify-center">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 12L6 6L9 9L11 5L14 12" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="text-[17px] font-bold tracking-tight text-surface-900 font-display group-hover:text-brand-500 transition-colors">
        Amplifyr
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-7">
      <a href="#resources" class="text-sm font-medium text-surface-800/70 hover:text-surface-900 transition-colors">Resources</a>
      <a href="#tools" class="text-sm font-medium text-surface-800/70 hover:text-surface-900 transition-colors">Tools</a>
      <a href="/blog" class="text-sm font-medium text-surface-800/70 hover:text-surface-900 transition-colors">Blog</a>
      <a href="#newsletter" class="text-sm font-medium text-surface-800/70 hover:text-surface-900 transition-colors">Newsletter</a>
    </div>

    <!-- CTA -->
    <a href="#newsletter" class="inline-flex items-center gap-1.5 text-sm font-semibold bg-brand-500 text-white px-4 py-2 rounded-lg hover:bg-brand-600 transition-colors">
      Get the Digest
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </nav>
</header>
