---
<footer class="bg-surface-950 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-10 border-b border-white/10">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 rounded-md bg-brand-500 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2 12L6 6L9 9L11 5L14 12" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="text-[17px] font-bold tracking-tight font-display text-white">Amplifyr</span>
        </a>
        <p class="text-sm text-white/50 max-w-xs leading-relaxed">
          The audience growth resource for marketers and creators who mean business.
        </p>
      </div>

      <!-- Nav Links -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Resources</h4>
        <ul class="space-y-3">
          <li><a href="#resources" class="text-sm text-white/60 hover:text-white transition-colors">Resource Library</a></li>
          <li><a href="#tools" class="text-sm text-white/60 hover:text-white transition-colors">Tool Reviews</a></li>
          <li><a href="/blog" class="text-sm text-white/60 hover:text-white transition-colors">Blog</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Company</h4>
        <ul class="space-y-3">
          <li><a href="#newsletter" class="text-sm text-white/60 hover:text-white transition-colors">Newsletter</a></li>
          <li><a href="#about" class="text-sm text-white/60 hover:text-white transition-colors">About</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-sm text-white/40">&copy; 2026 Amplifyr. Grow your audience. Own your reach.</p>
      <p class="text-sm text-white/30 italic">Research-backed. Vendor-neutral. Creator-first.</p>
    </div>
  </div>
</footer>
