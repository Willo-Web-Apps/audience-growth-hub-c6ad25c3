---
import Base from '../layouts/Base.astro';
---
<Base
  title="Amplifyr — Audience Growth Resources for Marketers & Creators"
  description="Strategies, tools, and community insights to grow your audience. Research-backed, practitioner-tested, zero vendor spin."
>

  <!-- ═══════════════════════════════════════════════════════════
       1. HERO SECTION
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden bg-surface-50 hero-grid">

    <!-- Layered gradient orbs -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full opacity-[0.07]"
           style="background: radial-gradient(circle, #1E40AF, transparent 70%); transform: translate(30%, -30%);"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full opacity-[0.05]"
           style="background: radial-gradient(circle, #F59E0B, transparent 70%); transform: translate(-30%, 30%);"></div>
      <!-- Geometric accent lines -->
      <svg class="absolute right-0 top-0 h-full w-1/2 opacity-[0.03]" viewBox="0 0 400 800" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="400" y1="0" x2="0" y2="800" stroke="#1E40AF" stroke-width="1"/>
        <line x1="380" y1="0" x2="0" y2="760" stroke="#1E40AF" stroke-width="1"/>
        <line x1="360" y1="0" x2="0" y2="720" stroke="#1E40AF" stroke-width="1"/>
        <line x1="420" y1="0" x2="20" y2="800" stroke="#F59E0B" stroke-width="0.5"/>
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-4xl">

        <!-- Category label -->
        <div class="animate-slide-up inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-100 border border-brand-200 mb-8">
          <span class="w-2 h-2 rounded-full bg-accent-500 inline-block"></span>
          <span class="text-xs font-semibold text-brand-600 tracking-wide uppercase">Audience Growth Intelligence</span>
        </div>

        <!-- Headline -->
        <h1 class="animate-slide-up delay-100 text-4xl md:text-5xl lg:text-[64px] font-bold tracking-tight text-surface-900 font-display leading-[1.08] max-w-3xl">
          The Audience Growth Resource for Marketers and Creators
          <span class="text-brand-500"> Who Mean Business.</span>
        </h1>

        <!-- Sub-copy -->
        <p class="animate-slide-up delay-200 mt-6 text-lg md:text-xl text-surface-800/60 max-w-2xl leading-relaxed font-body">
          Strategies, tools, and community insights to grow your audience — research-backed, practitioner-tested, zero vendor spin.
        </p>

        <!-- CTAs -->
        <div class="animate-slide-up delay-300 mt-10 flex flex-col sm:flex-row gap-4">
          <a href="#resources"
             class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-brand-500 text-white font-semibold rounded-lg hover:bg-brand-600 transition-colors text-[15px]">
            Browse the Resource Library
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#newsletter"
             class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-white text-surface-900 font-semibold rounded-lg border border-surface-200 hover:border-brand-400 hover:text-brand-500 transition-colors text-[15px]">
            Get the Free Weekly Digest
          </a>
        </div>

        <!-- Trust signal -->
        <div class="animate-slide-up delay-400 mt-10 flex items-center gap-3">
          <!-- Avatar stack -->
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-brand-400 border-2 border-white flex items-center justify-center text-white text-[10px] font-bold">JK</div>
            <div class="w-8 h-8 rounded-full bg-accent-500 border-2 border-white flex items-center justify-center text-white text-[10px] font-bold">SM</div>
            <div class="w-8 h-8 rounded-full bg-brand-600 border-2 border-white flex items-center justify-center text-white text-[10px] font-bold">AR</div>
            <div class="w-8 h-8 rounded-full bg-surface-800 border-2 border-white flex items-center justify-center text-white text-[10px] font-bold">+</div>
          </div>
          <p class="text-sm text-surface-800/60 font-medium">
            Join <span class="text-surface-900 font-semibold">10,000+ creators and marketers</span> leveling up their reach
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       2. VALUE PILLARS — "What You'll Find Here"
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-white border-t border-surface-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900 font-display">
          What You'll Find Here
        </h2>
        <p class="mt-4 text-lg text-surface-800/55 max-w-xl mx-auto">
          Everything you need to grow your audience — without the noise.
        </p>
      </div>

      <!-- 3-column pillars -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Pillar 1: Strategy Playbooks -->
        <div class="group relative p-8 rounded-2xl border border-surface-200 bg-surface-50 hover:border-brand-200 hover:bg-brand-50 transition-all duration-200">
          <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center text-2xl mb-6 group-hover:bg-brand-200 transition-colors">
            🎯
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3 tracking-tight">Strategy Playbooks</h3>
          <p class="text-surface-800/60 leading-relaxed text-[15px]">
            In-depth frameworks on platform growth, content strategy, monetization, and AI workflows. Built for practitioners, not beginners.
          </p>
          <div class="mt-6 flex items-center gap-1.5 text-brand-500 text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity">
            Explore playbooks
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <!-- Pillar 2: Honest Tool Reviews -->
        <div class="group relative p-8 rounded-2xl border border-surface-200 bg-surface-50 hover:border-accent-400 hover:bg-amber-50 transition-all duration-200">
          <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center text-2xl mb-6 group-hover:bg-amber-200 transition-colors">
            🛠️
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3 tracking-tight">Honest Tool Reviews</h3>
          <p class="text-surface-800/60 leading-relaxed text-[15px]">
            Unbiased, data-driven comparisons of the tools creators and marketers actually use — no affiliate games, no vendor bias.
          </p>
          <div class="mt-6 flex items-center gap-1.5 text-accent-600 text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity">
            Browse reviews
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <!-- Pillar 3: Trend Intelligence -->
        <div class="group relative p-8 rounded-2xl border border-surface-200 bg-surface-50 hover:border-brand-200 hover:bg-brand-50 transition-all duration-200">
          <div class="w-12 h-12 rounded-xl bg-brand-100 flex items-center justify-center text-2xl mb-6 group-hover:bg-brand-200 transition-colors">
            📊
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3 tracking-tight">Trend Intelligence</h3>
          <p class="text-surface-800/60 leading-relaxed text-[15px]">
            Stay ahead of algorithm changes, platform shifts, and what's actually working across the creator ecosystem right now.
          </p>
          <div class="mt-6 flex items-center gap-1.5 text-brand-500 text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity">
            See what's trending
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       3. STATS BANNER — Market Context
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 md:py-20" style="background: linear-gradient(135deg, #0F2168 0%, #1E40AF 50%, #1a3a9e 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <p class="text-center text-xs font-semibold uppercase tracking-widest text-white/40 mb-12">
        The Creator Economy — By the Numbers
      </p>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4">

        <div class="text-center">
          <div class="text-3xl md:text-4xl lg:text-5xl font-bold text-white font-display tracking-tight">$250B+</div>
          <div class="mt-2 text-sm text-white/55 leading-snug">Creator Economy<br/>in 2026</div>
        </div>

        <div class="text-center">
          <div class="text-3xl md:text-4xl lg:text-5xl font-bold text-white font-display tracking-tight">200M+</div>
          <div class="mt-2 text-sm text-white/55 leading-snug">Active Creators<br/>Worldwide</div>
        </div>

        <div class="text-center">
          <div class="text-3xl md:text-4xl lg:text-5xl font-bold font-display tracking-tight" style="color: #F59E0B;">171%</div>
          <div class="mt-2 text-sm text-white/55 leading-snug">Growth in Influencer<br/>Marketing Budgets YoY</div>
        </div>

        <div class="text-center">
          <div class="text-3xl md:text-4xl lg:text-5xl font-bold text-white font-display tracking-tight">50M+</div>
          <div class="mt-2 text-sm text-white/55 leading-snug">Professional Creators<br/>Competing for Audience</div>
        </div>

      </div>

      <!-- Bottom message -->
      <p class="mt-14 text-center text-white/60 text-sm max-w-xl mx-auto leading-relaxed">
        The competition for attention has never been greater. The right strategy is no longer optional —
        <span class="text-white font-medium">it's the difference between growing and disappearing.</span>
      </p>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       4. FEATURED RESOURCES
  ═══════════════════════════════════════════════════════════ -->
  <section id="resources" class="py-20 md:py-28 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900 font-display">
            Start With These →
          </h2>
          <p class="mt-2 text-surface-800/55 text-lg">Hand-picked resources to get you moving fast.</p>
        </div>
        <a href="/blog"
           class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-500 hover:text-brand-600 transition-colors whitespace-nowrap">
          View all resources
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Resource cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-7">

        <!-- Card 1: TikTok Guide -->
        <article class="group relative bg-white rounded-2xl border border-surface-200 overflow-hidden hover:shadow-lg hover:shadow-brand-500/8 hover:-translate-y-0.5 transition-all duration-200">
          <!-- Card visual header -->
          <div class="h-44 relative overflow-hidden" style="background: linear-gradient(135deg, #1E40AF 0%, #3B82F6 100%);">
            <div class="absolute inset-0 opacity-10 hero-grid"></div>
            <div class="absolute bottom-4 left-5 right-5">
              <div class="w-10 h-10 rounded-xl bg-white/20 backdrop-blur-sm flex items-center justify-center">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
            <!-- Decorative dots -->
            <div class="absolute top-5 right-5 grid grid-cols-3 gap-1.5 opacity-30">
              {Array(9).fill(null).map(() => (
                <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
              ))}
            </div>
          </div>

          <div class="p-6">
            <span class="inline-block px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide rounded-full bg-brand-100 text-brand-600 mb-4">
              Strategy Playbook
            </span>
            <h3 class="text-lg font-bold text-surface-900 font-display leading-snug mb-3 group-hover:text-brand-500 transition-colors">
              The Complete Guide to Growing on TikTok in 2026
            </h3>
            <p class="text-sm text-surface-800/55 leading-relaxed mb-5">
              Algorithm mechanics, content cadence, and the specific content formats that are driving follower growth right now. With platform-native examples.
            </p>
            <a href="/blog"
               class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-500 hover:text-brand-600 transition-colors">
              Read More →
            </a>
          </div>
        </article>

        <!-- Card 2: Tool Comparison -->
        <article class="group relative bg-white rounded-2xl border border-surface-200 overflow-hidden hover:shadow-lg hover:shadow-accent-500/8 hover:-translate-y-0.5 transition-all duration-200">
          <div class="h-44 relative overflow-hidden" style="background: linear-gradient(135deg, #92400E 0%, #F59E0B 100%);">
            <div class="absolute inset-0 opacity-10 hero-grid"></div>
            <div class="absolute bottom-4 left-5 right-5">
              <div class="w-10 h-10 rounded-xl bg-white/20 backdrop-blur-sm flex items-center justify-center">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
            <div class="absolute top-5 right-5 grid grid-cols-3 gap-1.5 opacity-30">
              {Array(9).fill(null).map(() => (
                <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
              ))}
            </div>
          </div>

          <div class="p-6">
            <span class="inline-block px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide rounded-full bg-amber-100 text-amber-700 mb-4">
              Tool Review
            </span>
            <h3 class="text-lg font-bold text-surface-900 font-display leading-snug mb-3 group-hover:text-accent-600 transition-colors">
              Top 12 Creator Tools Compared: Which Are Actually Worth It?
            </h3>
            <p class="text-sm text-surface-800/55 leading-relaxed mb-5">
              We tested every major scheduling, analytics, and monetization tool so you don't have to. Ranked by ROI, not by affiliate payout.
            </p>
            <a href="/blog"
               class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-600 hover:text-accent-500 transition-colors">
              Read More →
            </a>
          </div>
        </article>

        <!-- Card 3: Instagram Algorithm -->
        <article class="group relative bg-white rounded-2xl border border-surface-200 overflow-hidden hover:shadow-lg hover:shadow-brand-500/8 hover:-translate-y-0.5 transition-all duration-200">
          <div class="h-44 relative overflow-hidden" style="background: linear-gradient(135deg, #312e81 0%, #6366f1 100%);">
            <div class="absolute inset-0 opacity-10 hero-grid"></div>
            <div class="absolute bottom-4 left-5 right-5">
              <div class="w-10 h-10 rounded-xl bg-white/20 backdrop-blur-sm flex items-center justify-center">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="2" width="20" height="20" rx="5" stroke="white" stroke-width="1.5"/>
                  <circle cx="12" cy="12" r="4" stroke="white" stroke-width="1.5"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="white"/>
                </svg>
              </div>
            </div>
            <div class="absolute top-5 right-5 grid grid-cols-3 gap-1.5 opacity-30">
              {Array(9).fill(null).map(() => (
                <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
              ))}
            </div>
          </div>

          <div class="p-6">
            <span class="inline-block px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide rounded-full bg-indigo-100 text-indigo-700 mb-4">
              Platform Guide
            </span>
            <h3 class="text-lg font-bold text-surface-900 font-display leading-snug mb-3 group-hover:text-indigo-600 transition-colors">
              How the Instagram Algorithm Really Works (And How to Win It)
            </h3>
            <p class="text-sm text-surface-800/55 leading-relaxed mb-5">
              Beyond the myths. A signal-by-signal breakdown of what IG's ranking system actually rewards in 2026, with a clear action plan to use it.
            </p>
            <a href="/blog"
               class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-600 hover:text-indigo-700 transition-colors">
              Read More →
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       5. NEWSLETTER CTA
  ═══════════════════════════════════════════════════════════ -->
  <section id="newsletter" class="py-20 md:py-28" style="background: linear-gradient(to bottom, #f8fafc, #EFF6FF);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">

        <!-- Icon -->
        <div class="w-14 h-14 rounded-2xl bg-brand-100 border border-brand-200 flex items-center justify-center mx-auto mb-8">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="#1E40AF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <polyline points="22,6 12,13 2,6" stroke="#1E40AF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900 font-display mb-4">
          Get the Amplifyr Weekly Digest
        </h2>
        <p class="text-lg text-surface-800/60 leading-relaxed mb-10">
          Every week: the best audience growth strategies, platform updates, and creator insights — distilled into a 5-minute read. Free, always.
        </p>

        <!-- Email form -->
        <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" onsubmit="return false;">
          <input
            type="email"
            placeholder="your@email.com"
            class="flex-1 px-4 py-3.5 rounded-lg border border-surface-200 bg-white text-surface-900 text-[15px] placeholder:text-surface-800/35 focus:outline-none focus:border-brand-400 focus:ring-2 focus:ring-brand-400/20 transition-colors"
          />
          <button
            type="submit"
            class="px-6 py-3.5 bg-brand-500 text-white font-semibold rounded-lg hover:bg-brand-600 transition-colors text-[15px] whitespace-nowrap">
            Subscribe Free
          </button>
        </form>

        <!-- Trust signal -->
        <p class="mt-4 text-sm text-surface-800/45">
          No spam. Unsubscribe anytime. Loved by 10,000+ creators.
        </p>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       6. WHY AMPLIFYR — Differentiation
  ═══════════════════════════════════════════════════════════ -->
  <section id="about" class="py-20 md:py-28 bg-white border-t border-surface-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Left: copy -->
        <div>
          <span class="inline-block text-xs font-semibold uppercase tracking-widest text-brand-500 mb-4">
            Why Amplifyr
          </span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900 font-display mb-6">
            Built for Creators.<br/>Not for Vendors.
          </h2>
          <p class="text-lg text-surface-800/60 leading-relaxed max-w-md">
            Most "creator content" is just marketing dressed up as education. Amplifyr was built to be the resource we always wanted — honest, specific, and worth your time.
          </p>

          <a href="#resources"
             class="mt-8 inline-flex items-center gap-2 px-6 py-3 bg-brand-500 text-white font-semibold rounded-lg hover:bg-brand-600 transition-colors text-[15px]">
            Start reading
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Right: differentiator grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

          <div class="p-6 rounded-2xl bg-surface-50 border border-surface-200">
            <div class="w-9 h-9 rounded-lg bg-brand-100 flex items-center justify-center mb-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 12l2 2 4-4" stroke="#1E40AF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="12" r="9" stroke="#1E40AF" stroke-width="1.5"/>
              </svg>
            </div>
            <h4 class="font-bold text-surface-900 font-display mb-2">Brand-Neutral Voice</h4>
            <p class="text-sm text-surface-800/55 leading-relaxed">Independent editorial. No sponsors calling the shots on what we cover or how.</p>
          </div>

          <div class="p-6 rounded-2xl bg-surface-50 border border-surface-200">
            <div class="w-9 h-9 rounded-lg bg-brand-100 flex items-center justify-center mb-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
